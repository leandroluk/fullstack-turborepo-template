{
  "version": "0.2.0",
  "configurations": [
    { // template:api
      "name": "template:api",
      "type": "node",
      "request": "launch",
      "runtimeExecutable": "pnpm",
      "runtimeArgs": [
        "run",
        "start:debug"
      ],
      "cwd": "${workspaceFolder}/templates/${input:templatesApi}",
      "console": "integratedTerminal",
      "env": {
        "NODE_OPTIONS": "--no-deprecation"
      },
      "skipFiles": [
        "<node_internals>/**"
      ],
      "autoAttachChildProcesses": true,
      "sourceMaps": true
    },
    { // template:app
      "name": "template:app",
      "type": "node",
      "request": "launch",
      "runtimeExecutable": "pnpm",
      "runtimeArgs": [
        "run",
        "dev"
      ],
      "cwd": "${workspaceFolder}/templates/${input:templatesApp}",
      "console": "integratedTerminal",
      "env": {
        "NODE_OPTIONS": "--no-deprecation"
      },
      "skipFiles": [
        "<node_internals>/**"
      ]
    },
    { // template:aws-lambda-powertools
      "name": "template:aws-lambda-powertools",
      "type": "node",
      "request": "launch",
      "runtimeExecutable": "pnpm",
      "runtimeArgs": [
        "run",
        "dev:debug"
      ],
      "cwd": "${workspaceFolder}/templates/${input:templatesAwsLambdaPowertools}",
      "console": "integratedTerminal",
      "env": {
        "NODE_OPTIONS": "--no-deprecation"
      },
      "skipFiles": [
        "<node_internals>/**"
      ],
      "autoAttachChildProcesses": true,
      "sourceMaps": true
    },
    { // template:doc
      "name": "template:doc",
      "type": "node",
      "request": "launch",
      "runtimeExecutable": "pnpm",
      "runtimeArgs": [
        "run",
        "dev"
      ],
      "cwd": "${workspaceFolder}/templates/${input:templatesDoc}",
      "console": "integratedTerminal",
      "env": {
        "NODE_OPTIONS": "--no-deprecation"
      },
      "skipFiles": [
        "<node_internals>/**"
      ]
    },
    { // template:e2e
      "name": "template:e2e",
      "type": "node",
      "request": "launch",
      "runtimeExecutable": "pnpm",
      "runtimeArgs": [
        "run",
        "test:e2e"
      ],
      "cwd": "${workspaceFolder}/templates/${input:templatesE2e}",
      "console": "integratedTerminal"
    },
    { // template:k8s
      "name": "template:k8s",
      "type": "node",
      "request": "launch",
      "runtimeExecutable": "pnpm",
      "runtimeArgs": [
        "run",
        "debug"
      ],
      "cwd": "${workspaceFolder}/templates/${input:templatesK8s}",
      "console": "integratedTerminal",
      "skipFiles": [
        "<node_internals>/**"
      ],
      "autoAttachChildProcesses": true,
      "sourceMaps": true
    },
    { // template:serverless-v3
      "name": "template:serverless-v3",
      "type": "node",
      "request": "launch",
      "runtimeExecutable": "pnpm",
      "runtimeArgs": [
        "run",
        "dev:debug"
      ],
      "cwd": "${workspaceFolder}/templates/${input:templatesServerlessV3}",
      "console": "integratedTerminal",
      "env": {
        "NODE_OPTIONS": "--no-deprecation"
      },
      "skipFiles": [
        "<node_internals>/**"
      ],
      "autoAttachChildProcesses": true,
      "sourceMaps": true
    },
    { // template:web
      "name": "template:web",
      "type": "node",
      "request": "launch",
      "runtimeExecutable": "pnpm",
      "runtimeArgs": [
        "run",
        "dev"
      ],
      "cwd": "${workspaceFolder}/templates/${input:templatesWeb}",
      "console": "integratedTerminal",
      "env": {
        "NODE_OPTIONS": "--no-deprecation"
      },
      "skipFiles": [
        "<node_internals>/**"
      ]
    },
  ],
  "inputs": [
    { // template:api
      "id": "templatesApi",
      "type": "pickString",
      "description": "Selecione a API",
      "options": [
        "api"
      ]
    },
    { // template:app
      "id": "templatesApp",
      "type": "pickString",
      "description": "Selecione o App",
      "options": [
        "app"
      ]
    },
    { // template:aws-lambda-powertools
      "id": "templatesAwsLambdaPowertools",
      "type": "pickString",
      "description": "Selecione a AWS Lambda Powertools",
      "options": [
        "aws-lambda-powertools"
      ]
    },
    { // template:doc
      "id": "templatesDoc",
      "type": "pickString",
      "description": "Selecione a Documentação",
      "options": [
        "doc"
      ]
    },
    { // template:e2e
      "id": "templatesE2e",
      "type": "pickString",
      "description": "Selecione o Suite E2E",
      "options": [
        "e2e"
      ]
    },
    { // template:k8s
      "id": "templatesK8s",
      "type": "pickString",
      "description": "Selecione o K8s",
      "options": [
        "k8s"
      ]
    },
    { // template:serverless-v3
      "id": "templatesServerlessV3",
      "type": "pickString",
      "description": "Selecione o Serverless V3",
      "options": [
        "serverless-framework-v3"
      ]
    },
    { // template:web
      "id": "templatesWeb",
      "type": "pickString",
      "description": "Selecione o Frontend",
      "options": [
        "web"
      ]
    }
  ]
}