{
  "extends": "@packages/config-typescript/base.json",
  "compilerOptions": {
    "outDir": "dist",
    "target": "es2020",
    "module": "nodenext",
    "moduleResolution": "nodenext",
    "experimentalDecorators": true,
    "pretty": true,
    "noFallthroughCasesInSwitch": true,
    "noImplicitReturns": true
  },
  "include": [
    "src/**/*.ts",
    "eslint.config.ts"
  ],
  "exclude": [
    "node_modules",
    "dist"
  ]
}