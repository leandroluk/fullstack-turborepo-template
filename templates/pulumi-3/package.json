{
  "name": "@templates/pulumi-3",
  "version": "0.0.1",
  "description": "Template de projeto usando Kubernetes e já configurado com configs de monorepo",
  "private": true,
  "type": "module",
  "license": "UNLICENSED",
  "main": "src/index.ts",
  "scripts": {
    "lint": "eslint src --fix",
    "typecheck": "tsc --noEmit",
    "cluster:setup": "dotenvx run -- node scripts/setup-cluster.js",
    "cluster:teardown": "dotenvx run -- node scripts/teardown-cluster.js",
    "docker:push": "dotenvx run -- node scripts/docker-push.js",
    "deploy": "dotenvx run -- node scripts/deploy.js",
    "pipeline": "dotenvx run -- node scripts/docker-push.js && dotenvx run -- node scripts/deploy.js",
    "preview:local": "pulumi preview --stack local",
    "up:local": "pulumi up --yes --stack local",
    "destroy:local": "pulumi destroy --yes --stack local",
    "local": "pnpm cluster:setup && pnpm docker:push && pnpm deploy"
  },
  "dependencies": {
    "@pulumi/aws": "7.24.0",
    "@pulumi/awsx": "^3.0.0",
    "@pulumi/eks": "^3.0.0",
    "@pulumi/gcp": "9.19.0",
    "@pulumi/hcloud": "1.32.1",
    "@pulumi/kubernetes": "4.28.0",
    "@pulumi/pulumi": "^3.113.0"
  },
  "devDependencies": {
    "@dotenvx/dotenvx": "^1.44.0",
    "@packages/config-eslint": "workspace:*",
    "@packages/config-typescript": "workspace:*",
    "@packages/config-vitest": "workspace:*",
    "@types/node": "^25.0.0",
    "eslint": "^10.2.0",
    "typescript": "^5.9.3",
    "vitest": "^4.1.4"
  }
}
