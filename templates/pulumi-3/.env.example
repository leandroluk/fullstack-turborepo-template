# Stack to deploy — local | baremetal | aws | gcp | hcloud
STACK=local

# Container registry and image tag
# In CI use the git SHA as TAG so Pulumi detects image changes per-deployment
REGISTRY=localhost:5000
TAG=latest

# Set to "true" to skip turbo change detection and rebuild all app images
FORCE_DEPLOY=false

# k3d cluster (local only)
CLUSTER_NAME=fullstack
REGISTRY_NAME=registry.localhost
REGISTRY_PORT=5000
