{
  "extends": "@packages/config-typescript/base.json",
  "compilerOptions": {
    "outDir": "bin",
    "target": "es2020",
    "module": "nodenext",
    "moduleResolution": "nodenext",
    "experimentalDecorators": true,
    "pretty": true,
    "noFallthroughCasesInSwitch": true,
    "noImplicitReturns": true
  },
  "include": [
    "**/*.ts",
  ],
  "exclude": [
    "node_modules",
    "bin"
  ]
}