{
  "name": "@packages/config-eslint",
  "version": "0.0.1",
  "description": "Shared ESLint configurations for the monorepo.",
  "type": "module",
  "private": true,
  "exports": {
    "./base": {
      "types": "./dist/base.d.ts",
      "import": "./dist/base.js",
      "default": "./dist/base.js"
    },
    "./nest": {
      "types": "./dist/nest.d.ts",
      "import": "./dist/nest.js",
      "default": "./dist/nest.js"
    },
    "./next": {
      "types": "./dist/next.d.ts",
      "import": "./dist/next.js",
      "default": "./dist/next.js"
    },
    "./react": {
      "types": "./dist/react.d.ts",
      "import": "./dist/react.js",
      "default": "./dist/react.js"
    },
    "./expo": {
      "types": "./dist/expo.d.ts",
      "import": "./dist/expo.js",
      "default": "./dist/expo.js"
    }
  },
  "scripts": {
    "build": "tsup",
    "lint": "eslint . --fix --cache --cache-location .eslintcache",
    "typecheck": "tsc --noEmit"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.0",
    "@next/eslint-plugin-next": "^16.2.0",
    "@vitest/eslint-plugin": "1.6.15",
    "eslint": "^10.2.0",
    "eslint-config-expo": "~55.0.0",
    "eslint-config-prettier": "^10.1.1",
    "eslint-plugin-only-warn": "^1.1.0",
    "eslint-plugin-prettier": "5.5.5",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^5.2.0",
    "eslint-plugin-turbo": "^2.7.1",
    "globals": "^16.5.0",
    "tsup": "^8.1.0",
    "typescript": "^5.9.2",
    "typescript-eslint": "^8.58.0"
  }
}